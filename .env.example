# Copy to .env.local and fill in. NEXT_PUBLIC_* are client-exposed; the
# SUPABASE_* keys below are SERVER-ONLY — never add a NEXT_PUBLIC_ prefix.

# PostHog (funnel analytics) — EU ingestion host
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta Pixel (Lead optimisation event). Server-side CAPI is handled by Meta's
# one-click "Set up with Meta" in Events Manager — no token/keys needed here.
NEXT_PUBLIC_META_PIXEL_ID=

# Landing page URL (Q1 back button destination), e.g. https://getbarbr.com
NEXT_PUBLIC_LANDING_URL=

# Fixed UI theme (no in-app toggle): light | dark | neon. Default neon.
NEXT_PUBLIC_THEME=neon

# Supabase (SERVER-ONLY lead storage) — optional; flow runs without it.
# Writes go through /api/lead & /api/handle with the service_role key. Do NOT
# prefix with NEXT_PUBLIC_ — the service_role key must never reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Slack lead notifications (SERVER-ONLY) — optional; flow runs without it.
# Pings the four funnel milestones (quiz start → Q1 → email → download) as ONE
# threaded message per session, via chat.postMessage. Set up a Slack app with a
# Bot Token Scope of `chat:write`, install it, invite the bot to the channel,
# then paste the bot token (xoxb-…) and the channel ID (e.g. C0123456789) below.
# Do NOT prefix with NEXT_PUBLIC_ — the bot token must never reach the browser.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
