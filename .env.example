# Copy to .env.local and fill in. All client-exposed (NEXT_PUBLIC_*).

# PostHog (funnel analytics) — EU ingestion host
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta Pixel (Lead optimisation event)
NEXT_PUBLIC_META_PIXEL_ID=

# Supabase (lead storage) — optional; flow runs without it
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
